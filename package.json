{
  "name": "@conscius/source",
  "version": "0.5.0-alpha.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "pr:feedback": "node scripts/check-pr-feedback.mjs",
    "test:mulch-record-interactive": "bash scripts/verify-mulch-record-interactive.sh"
  },
  "private": true,
  "devDependencies": {
    "@nx/eslint": "^22.5.4",
    "@nx/jest": "^22.5.4",
    "@nx/js": "22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "~8.57.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "lint-staged": "^16.3.2",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "verdaccio": "^6.0.5"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.mjs": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
